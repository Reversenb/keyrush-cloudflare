generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  
}

model Mission {
  id              String     @id @default(uuid()) 
  os              String     
  difficulty      String     @default("basic") 
  level           Int        
  title           String     
  description     String     
  expectedCommand String     
  hint            String?    
  rewardExp       Int        @default(100) 
  createdAt       DateTime   @default(now()) 
  updatedAt       DateTime   @updatedAt      
  Progress        Progress[]
  @@unique([os, level]) 
}

model Progress {
  id         String    @id @default(uuid())
  isPassed   Boolean   @default(false)
  errorCount Int       @default(0) 
  wpm        Int       @default(0) 
  accuracy   Int       @default(0)
  usedReveal Boolean   @default(false)
  passedAt   DateTime?
  userId     String
  missionId  String
  Mission    Mission   @relation(fields: [missionId], references: [id], onDelete: Cascade)
  User       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([userId, missionId])
}

model User {
  id               String    @id @default(uuid())
  username         String    @unique
  email            String?   @unique
  googleId         String?   @unique
  displayName      String?
  avatar           String?   @default("Felix")
  bio              String?
  role             String    @default("user")
  adminFavorites   String    @default("[]")
  tokenVersion     Int       @default(0)
  linuxLevel       Int       @default(1)
  linuxExp         Int       @default(0)
  windowsLevel     Int       @default(1)
  windowsExp       Int       @default(0)
  // 🪙 ระบบร้านค้า — เหรียญได้จากการเล่นเท่านั้น (server แจกในจุดที่ตรวจแล้ว)
  coins            Int       @default(0)
  equippedTitle    String?   // itemId ของฉายาที่ใส่อยู่
  equippedTerminal String?   // (เลิกใช้แล้ว) ชุดสี terminal เดิม
  equippedTheme    String?   // itemId ของธีมเว็บที่ใส่อยู่
  equippedCursor   String?   // itemId ของเอฟเฟกต์เมาส์ที่ใส่อยู่
  equippedFrame    String?   // itemId ของกรอบรูปโปรไฟล์ที่ใส่อยู่
  equippedRow      String?   // itemId ของเอฟเฟกต์แถว Leaderboard ที่ใส่อยู่
  createdAt        DateTime  @default(now())
  Progress         Progress[]
  playHistories    PlayHistory[]
  items            UserItem[]
}

// ==========================================
// 🛍️ ของที่ผู้เล่นซื้อไว้ (แคตตาล็อกอยู่ใน src/shop/items.ts ฝั่ง server)
// ==========================================
model UserItem {
  id        String   @id @default(uuid())
  userId    String
  itemId    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([userId, itemId])
}

model PlayHistory {
  id        String   @id @default(uuid())
  userId    String
  os        String
  level     Int
  wpm       Int
  accuracy  Int
  earnedExp Int?     // EXP ที่ได้จริงรอบนั้น (หลังหักโทษเฉลย, 0 = รอบเล่นซ้ำ, null = record เก่าก่อนมี field นี้)
  earnedCoins Int?   // 🪙 เหรียญที่ได้รอบนั้น (null = record เก่าก่อนมี field นี้)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
// ==========================================
// 📚 ตารางคู่มือคำสั่ง (Docs)
// ==========================================
model CommandDoc {
  id          String   @id @default(uuid())
  os          String   // 'linux' หรือ 'windows'
  category    String   // หมวดหมู่ เช่น 'File System', 'Network'
  command     String   // ตัวคำสั่ง เช่น 'ls', 'dir'
  description String   // คำอธิบายคำสั่ง
  example     String?  // ตัวอย่างการพิมพ์ (มีหรือไม่มีก็ได้)
  createdAt   DateTime @default(now())
}